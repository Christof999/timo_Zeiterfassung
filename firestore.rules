rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Die App nutzt Firebase Auth (u. a. anonym). Nur angemeldete Clients dürfen zugreifen.
    // Für Produktion: feinere Regeln (z. B. Admin-Claims, getrennte Leserechte).
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
