# Firebase Web-App (Vite) – Werte aus der Firebase Console (Projekt: timozeiterfassung)
# Kopiere diese Datei nach .env und ersetze die Platzhalter durch deine echten Werte.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=timozeiterfassung.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=timozeiterfassung
# Exakten Bucket aus der Console übernehmen (häufig …appspot.com oder …firebasestorage.app)
VITE_FIREBASE_STORAGE_BUCKET=timozeiterfassung.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional Web Push (öffentlicher VAPID-Key)
VITE_PUSH_VAPID_PUBLIC_KEY=

# Server (z. B. Vercel) – Firebase Admin + Push; siehe FIREBASE.md
FIREBASE_PROJECT_ID=timozeiterfassung
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@timozeiterfassung.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
PUSH_VAPID_PRIVATE_KEY=dein-vapid-private-key
PUSH_VAPID_SUBJECT=mailto:admin@deine-domain.de
# Optional: alternativer Service-Token statt Firebase ID Token
PUSH_API_TOKEN=optional-service-token
