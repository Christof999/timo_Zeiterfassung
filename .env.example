# Firebase Konfiguration - Kopiere diese Datei zu .env und fulle die Werte aus
VITE_FIREBASE_API_KEY=dein-api-key
VITE_FIREBASE_AUTH_DOMAIN=dein-projekt.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=dein-projekt-id
VITE_FIREBASE_STORAGE_BUCKET=dein-projekt.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=deine-sender-id
VITE_FIREBASE_APP_ID=deine-app-id
VITE_PUSH_VAPID_PUBLIC_KEY=dein-vapid-public-key

# Server (Vercel Function) - im Vercel Projekt als Environment Variables setzen
FIREBASE_PROJECT_ID=dein-firebase-projekt-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@dein-projekt.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
PUSH_VAPID_PRIVATE_KEY=dein-vapid-private-key
PUSH_VAPID_SUBJECT=mailto:admin@deine-domain.de
# Optional: alternativer Service-Token statt Firebase ID Token
PUSH_API_TOKEN=optional-service-token
